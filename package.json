  "scripts": {
    "prepare": "husky",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "pnpm lint:code && pnpm lint:md",
    "lint:fix": "pnpm md:headings && pnpm lint:code:fix && pnpm lint:md:fix",
    "lint:affected": "nx affected -t lint",
    "lint:code": "nx run-many -t lint",
    "lint:code:fix": "nx run-many -t lint --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" \"#coverage\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\" \"#dist\" \"#coverage\"",
    "md:headings": "node tools/scripts/fix-markdown-headings.mjs",
    "typecheck": "nx run-many -t typecheck",
    "typecheck:affected": "nx affected -t typecheck",
    "test": "nx run-many -t test",
    "test:watch": "nx run-many -t test --watch",
    "test:coverage": "nx run-many -t test --coverage",
    "test:affected": "nx affected -t test",
    "e2e": "nx run-many -t e2e",
    "e2e:affected": "nx affected -t e2e",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "fix": "pnpm format && pnpm lint:fix"
  },
