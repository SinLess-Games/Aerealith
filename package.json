  "scripts": {
    "prepare": "husky",
    "nx": "nx",
    "graph": "nx graph",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "lint:affected": "nx affected -t lint",
    "typecheck": "nx run-many -t typecheck",
    "typecheck:affected": "nx affected -t typecheck",
    "test": "nx run-many -t test",
    "test:watch": "nx run-many -t test --watch",
    "test:coverage": "nx run-many -t test --coverage",
    "test:affected": "nx affected -t test",
    "e2e": "nx run-many -t e2e",
    "build": "nx run-many -t build",
    "build:affected": "nx affected -t build",
    "frontend:dev": "nx run frontend:serve:development",
    "frontend:serve": "nx run frontend:serve",
    "frontend:serve:preview": "nx run frontend:serve:preview",
    "frontend:serve:staging": "nx run frontend:serve:staging",
    "frontend:serve:production": "nx run frontend:serve:production",
    "frontend:build": "nx run frontend:build",
    "frontend:build:development": "nx run frontend:build:development",
    "frontend:build:preview": "nx run frontend:build:preview",
    "frontend:build:staging": "nx run frontend:build:staging",
    "frontend:build:production": "nx run frontend:build:production",
    "frontend:preview": "nx run frontend:preview:production",
    "frontend:preview:development": "nx run frontend:preview:development",
    "frontend:preview:preview": "nx run frontend:preview:preview",
    "frontend:preview:staging": "nx run frontend:preview:staging",
    "frontend:preview:production": "nx run frontend:preview:production",
    "frontend:deploy:preview": "wrangler versions upload --config apps/frontend/wrangler.toml",
    "frontend:deploy:staging": "wrangler versions upload --config apps/frontend/wrangler.toml --preview-alias staging",
    "frontend:deploy:production": "wrangler deploy --config apps/frontend/wrangler.toml",
    "services:new": "nx g @aerealith/service-generator:service --name",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "fix": "pnpm format && pnpm lint:fix",
    "clean": "nx reset && rimraf dist coverage .nx/cache",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
