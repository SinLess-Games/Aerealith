# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------

/node_modules/

# pnpm keeps its global store outside the repository by default, but this
# covers any local package-manager cache that may be created.
.pnpm-store/

# -----------------------------------------------------------------------------
# Build output and generated artifacts
# -----------------------------------------------------------------------------

/dist/
/tmp/
/out-tsc/
/coverage/
/reports/
/storybook-static/

/build/
/public/build/
/public/assets/

*.tsbuildinfo

# Vite / Vitest generated files.
.vite/
vite.config.*.timestamp*
vitest.config.*.timestamp*

# -----------------------------------------------------------------------------
# Nx
# -----------------------------------------------------------------------------

/.nx/cache/
/.nx/workspace-data/
/.nx/migrate-runs/
/.nx/installation/

# -----------------------------------------------------------------------------
# Test output
# -----------------------------------------------------------------------------

/test-results/
/playwright-report/
/blob-report/
/allure-results/
/allure-report/

# -----------------------------------------------------------------------------
# Runtime logs and debug output
# -----------------------------------------------------------------------------

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

/connect.lock
/libpeerconnection.log
/testem.log

# -----------------------------------------------------------------------------
# Environment files and local secrets
# -----------------------------------------------------------------------------

.env
.env.*
!.env.example
!.env.*.example

# Cloudflare Workers local development bindings/secrets.
.dev.vars
.dev.vars.*
!.dev.vars.example
!.dev.vars.*.example

# Wrangler local state and generated files.
.wrangler/

# -----------------------------------------------------------------------------
# Editor and IDE files
# -----------------------------------------------------------------------------

/.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# Keep intentional shared VS Code settings, but ignore personal editor state.
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# AI assistant local state
# -----------------------------------------------------------------------------

/.claude/worktrees/
/.claude/settings.local.json

/.codex/
/.cache/codex/

# -----------------------------------------------------------------------------
# Miscellaneous temporary files
# -----------------------------------------------------------------------------

/.sass-cache/
/typings/

*.bak
*.tmp
*.temp
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Repository-local files not intended for source control
# -----------------------------------------------------------------------------

/notes.md

# MegaLinter output.
/megalinter-reports/
/mega-linter.log
