{
  "name": "<%= projectName %>",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/services/<%= serviceName %>/src",
  "projectType": "application",
  "tags": ["scope:services", "type:service"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/services/<%= serviceName %>",
        "main": "apps/services/<%= serviceName %>/src/main.ts",
        "tsConfig": "apps/services/<%= serviceName %>/tsconfig.app.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/services/<%= serviceName %>/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "test": {
      "executor": "@nx/vitest:vitest",
      "options": {
        "passWithNoTests": true,
        "configFile": "apps/services/<%= serviceName %>/vitest.config.mts"
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "<%= projectName %>:build"
      }
    }
  }
}
