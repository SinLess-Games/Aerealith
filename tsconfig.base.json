{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "nodenext",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@aerealith-ai/core": ["./libs/core/src/index.ts"],
      "@aerealith-ai/db": ["./libs/db/src/index.ts"],
      "@aerealith-ai/ui": ["./libs/ui/src/index.ts"],
      "@aerealith-ai/ui/*": ["./libs/ui/src/*"],
      "@aerealith-ai/ui/styles/*": ["./libs/ui/src/styles/*"],
      "@aerealith-ai/frontend/lib": ["./apps/frontend/src/lib"],
      "@aerealith-ai/frontend/lib/*": ["./apps/frontend/src/lib/*"],
      "@aerealith-ai/utils": ["./libs/utils/src/index.ts"],
      "@aerealith-ai/service-generator": [
        "./tools/generators/service/src/index.ts"
      ],
      "@aerealith-ai/content": ["./libs/content/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
